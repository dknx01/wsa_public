{% extends 'base.html.twig' %}
{% block title %}Benutzerdetails{% endblock %}

{% block body %}
{{ include('admin/menu.html.twig') }}

<div class="jumbotron">
    {{ include('layout/flash_messages.html.twig') }}
    <div class="card">
        <div class="card-body" id="userForm">
            {{ form_start(form) }}
            {% if errors is defined %}
                {% for error in errors %}
                    <div class="alert alert-danger">{{ error }}</div>
                {% endfor %}
            {% endif %}
            <div class="form-group">
                {{ form_label(form.email) }}
                <small id="emailHelp" class="form-text text-muted">{{ form_help(form.email) }}</small>
                {{ form_widget(form.email) }}
            </div>
            <div class="form-group">
                {{ form_label(form.active) }}
                <small id="activeHelp" class="form-text text-muted">{{ form_help(form.active) }}</small>
                {{ form_widget(form.active) }}
            </div>
            <div class="form-group">
                {{ form_label(form.submit) }}
                {{ form_widget(form.submit) }}
            </div>
            {{ form_row(form._token) }}
            {{ form_end(form, {render_rest: false}) }}

        </div>
    </div>
{% endblock %}
