    <style>
      .shadow-blur::after {
        --gradient: var({{ '--wsa-gradient-dark' }}) !important;
      }
    </style>

    <div class="Wsa-Header header-grid">
        <div class="header-item-logo ">
        {{ include('wsa/stern.html.twig') }}
        </div>
        <div class="header-item-title">
            <span>Finde das Unterstützungsunterschriften-Formular für dein Bundesland oder Direktkandidierenden</span><br>
        </div>
        <div class="header-item-search">
                <input type="text" id="search" class="form-control" data-action="input->document#search" placeholder="Suche deinen Wahlkreis">
        </div>
        <div class="header-item-help">
            <nav class="navbar navbar-expand-lg">
                <div class="container-fluid">
                    <div class="" id="navbarSupportedContent">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('help') }}">Hilfe beim Ausfüllen</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_statistic_index') }}">Stand der UUs</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('faq') }}">FAQ</a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </div>
    </div>
    <div class="Wsa-Tableau" >
        <div class="main-area">
            {{ include('snippets/loader.html.twig') }}

            <div class="states">
                {{ include('snippets/menu.html.twig') }}
                <div id="states">
                    {% for key, state in states %}
                        <button class="title-state" data-action="click->document#load" data-document-state-param="{{ state }}">{{ key }}</button>
                    {% endfor %}
                </div>
            </div>
            <div class="content Wsa-CardSlot" id="documents">
            </div>
        </div>
    </div>
